# =============================================
# Inventro — Docker Ignore
# =============================================

# Git
.git
.gitignore

# Docker configs (não precisa dentro do container)
docker-compose.yml
docker-compose.override.yml
docker-compose.prod.yml
.dockerignore
Makefile

# IDE / Editor
.idea/
.vscode/
.vs/
.claude/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Documentação (não vai para produção)
Documentation Inventory/

# Logs antigos
*.log
error_log

# Dados do MySQL (mantidos no volume)
docker/mysql/data/

# Arquivos temporários
*.tmp
*.temp
*.bak

# Backups SQL soltos
*.sql
!docker/mysql/init/*.sql

# Arquivos de teste
test.php

# Env local (credenciais ficam no docker-compose)
.env
.env.*
!.env.example

# Archives
*.zip
*.tar.gz
*.rar
